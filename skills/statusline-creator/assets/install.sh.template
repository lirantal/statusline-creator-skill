#!/usr/bin/env bash
# install.sh вҖ” installer for <TOOL_NAME> statusline for Claude Code
#
# Usage:
#   ./install.sh           install or update
#   ./install.sh --remove  remove from Claude Code settings
#
# Placeholders to fill in:
#   TOOL_NAME          вҖ” short name used in messages (e.g. "snyk")
#   TOOL_BIN_DEFAULT   вҖ” default binary name (e.g. "snyk", "trivy", "gh")
#   TOOL_AUTH_CHECK    вҖ” command that exits 0 if authenticated (e.g. "snyk whoami --experimental")
#   TOOL_AUTH_DO       вҖ” command to authenticate (e.g. "snyk auth") вҖ” shown in message, NOT run
#   TOOL_MISSING_HINT  вҖ” install hint shown when binary is not found (e.g. "npm install -g snyk")
#   STATUSLINE_SCRIPT  вҖ” relative path to statusline.sh (e.g. "statusline.sh")

set -euo pipefail

TOOL_NAME="<TOOL_NAME>"
TOOL_BIN_DEFAULT="<TOOL_BIN_DEFAULT>"
STATUSLINE_SCRIPT="$(cd "$(dirname "$0")" && pwd)/<STATUSLINE_SCRIPT>"
SETTINGS_FILE="${HOME}/.claude/settings.json"

# в”Җв”Җ Colors в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

R=$'\033[0m'
GREEN=$'\033[32m'
YELLOW=$'\033[33m'
RED=$'\033[31m'
BOLD=$'\033[1m'

die()  { printf '%sвңҳ%s  %s\n' "$RED"    "$R" "$*" >&2; exit 1; }
info() { printf '%sв„№%s  %s\n' "$YELLOW" "$R" "$*"; }
ok()   { printf '%sвң”%s  %s\n' "$GREEN"  "$R" "$*"; }

# в”Җв”Җ Remove mode в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

if [[ "${1:-}" == "--remove" ]]; then
    printf '\n%s%s вҖ” Uninstaller%s\n\n' "$BOLD" "$TOOL_NAME" "$R"
    if [[ ! -f "$SETTINGS_FILE" ]]; then
        info "No settings file found вҖ” nothing to remove."
        exit 0
    fi
    jq 'del(.statusLine)' "$SETTINGS_FILE" > "${SETTINGS_FILE}.tmp" \
        && mv "${SETTINGS_FILE}.tmp" "$SETTINGS_FILE"
    ok "statusLine entry removed from $SETTINGS_FILE"
    info "To also remove cached scan results:"
    printf '    rm -rf "${XDG_CACHE_HOME:-$HOME/.cache}/%s-statusline"\n' "$TOOL_NAME"
    printf '\n'
    info "Restart Claude Code for the change to take effect."
    exit 0
fi

# в”Җв”Җ Install в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

printf '\n%s%s вҖ” Installer%s\n\n' "$BOLD" "$TOOL_NAME" "$R"

# 1. Check script exists and is executable
[[ -f "$STATUSLINE_SCRIPT" ]] || die "statusline script not found at $STATUSLINE_SCRIPT"
chmod +x "$STATUSLINE_SCRIPT"
ok "statusline.sh is executable"

# 2. Check required dependencies
printf '\nChecking dependencies...\n'

## jq
if ! command -v jq &>/dev/null; then
    die "jq not found. Install it:
    macOS:  brew install jq
    Debian: sudo apt install jq
    Alpine: apk add jq"
fi
ok "jq found ($(jq --version))"

## Main tool binary
TOOL_BIN="${TOOL_BIN:-$TOOL_BIN_DEFAULT}"
if ! command -v "$TOOL_BIN" &>/dev/null; then
    die "$TOOL_NAME CLI not found. Install it:
    <TOOL_MISSING_HINT>
    Then re-run this installer."
fi
ok "$TOOL_NAME CLI found ($TOOL_BIN)"

# 3. Auth preflight вҖ” check only, never run the auth command automatically
printf '\nChecking authentication...\n'
if ! <TOOL_AUTH_CHECK> &>/dev/null; then
    printf '\n'
    die "$TOOL_NAME is not authenticated.
    Run: <TOOL_AUTH_DO>
    Then re-run this installer."
fi
ok "authenticated"

# 4. Install into ~/.claude/settings.json
printf '\nConfiguring Claude Code settings...\n'

mkdir -p "$(dirname "$SETTINGS_FILE")"

if [[ ! -f "$SETTINGS_FILE" ]]; then
    jq -n --arg p "$STATUSLINE_SCRIPT" \
        '{"statusLine": {"type": "command", "command": $p}}' > "$SETTINGS_FILE"
    ok "Created $SETTINGS_FILE with statusLine"
else
    jq --arg p "$STATUSLINE_SCRIPT" \
       '.statusLine = {"type": "command", "command": $p}' \
       "$SETTINGS_FILE" > "${SETTINGS_FILE}.tmp" \
       && mv "${SETTINGS_FILE}.tmp" "$SETTINGS_FILE"
    ok "Updated $SETTINGS_FILE with statusLine"
fi

# 5. Done вҖ” print configuration hints
printf '\n%sDone!%s Restart Claude Code for the statusline to appear.\n\n' "$GREEN" "$R"

printf 'Configuration (set in your shell profile or in ~/.claude/settings.json under "env"):\n'
printf '  %-34s %s\n' "TOOL_BIN" "Path to the $TOOL_NAME CLI (default: $TOOL_BIN_DEFAULT)"
printf '  %-34s %s\n' "<TOOL_NAME_UPPER>_STATUSLINE_TTL" "Seconds between scans (default: 300)"
printf '  %-34s %s\n' "<TOOL_NAME_UPPER>_SHOW_LOW" "Show low-severity issues (default: false)"
printf '  %-34s %s\n' "<TOOL_NAME_UPPER>_SCAN_ARGS" "Extra args passed to the scan command"
printf '\n'
printf 'To uninstall: %s./install.sh --remove%s\n\n' "$BOLD" "$R"
